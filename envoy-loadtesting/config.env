# Shared infrastructure
WC=envoyloadtesting
MC=graveler
BASE_DOMAIN=gaws2.gigantic.io
AZ=eu-north-1a
RELEASE=34.1.0

# Cluster contexts (kubectl context names)
MC_CONTEXT=graveler                  # Management cluster — WC App CRs applied here
WC_CONTEXT=graveler-coolertyp        # Workload cluster — Helm chart + ingress/envoy here
K6_CONTEXT=alba-seu01                # k6 cluster — TestRun + scenario ConfigMap here

# k6 load testing
K6_NAMESPACE=gs-k6-operator
K6_IMAGE=gsoci.azurecr.io/giantswarm/k6:1.6.0
ENDPOINTS=10
SCENARIO_DURATION_SECONDS=1200
WAIT_BETWEEN_SCENARIOS=300
ARRIVAL_RATE=26
PRE_ALLOCATED_VUS=50
MAX_VUS=150
GRACEFUL_STOP=30s
SLO_P95_LATENCY_MS=500
SLO_P99_LATENCY_MS=1000
SLO_ERROR_RATE=0.001
SLO_CHECKS_RATE=0.95
